# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ewaste
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/ewaste

# ── Object Storage (S3-compatible) ────────────────────────────────────────────
S3_BUCKET=ewaste-raw-data
S3_ENDPOINT_URL=                        # Leave blank for AWS S3; set for MinIO/R2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── Auth0 ─────────────────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.ewastetradeflow.com
AUTH0_CLIENT_ID=                        # Frontend SPA client ID
AUTH0_CLIENT_SECRET=                    # API M2M client secret (for admin routes)

# ── External APIs ─────────────────────────────────────────────────────────────
# World Bank Comtrade (registration at comtradeplus.un.org)
COMTRADE_API_KEY=

# OECD.Stat (free, no key needed — set base URL if using a proxy)
OECD_API_BASE_URL=https://stats.oecd.org/SDMX-JSON/data

# World Bank Databank (free, no key needed)
WB_API_BASE_URL=https://api.worldbank.org/v2

# ── Puppeteer microservice ─────────────────────────────────────────────────────
PUPPETEER_SERVICE_URL=http://localhost:3001
PUPPETEER_INTERNAL_KEY=change-me-in-production

# ── Redis (optional — app degrades gracefully without it) ─────────────────────
REDIS_URL=redis://localhost:6379/0

# ── App settings ──────────────────────────────────────────────────────────────
ENV=development                         # development | staging | production
API_PORT=8000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Maptiler (MapLibre base tiles) ────────────────────────────────────────────
MAPTILER_API_KEY=                       # Server-side / pipeline use

# ── Frontend (Vite) — these are embedded in the JS bundle at build time ────────
# Get a free MapTiler key at https://www.maptiler.com/cloud/
VITE_MAPTILER_KEY=

# API base URL for the frontend (no trailing slash)
VITE_API_URL=http://localhost:8000

# Auth0 SPA credentials — leave blank to disable login (app still works read-only)
VITE_AUTH0_DOMAIN=                      # e.g. your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=                   # SPA Application client_id from Auth0 dashboard
VITE_AUTH0_AUDIENCE=                    # e.g. https://api.ewastetradeflow.com

# ── UN Global E-Waste Monitor ingestion ───────────────────────────────────────
# URL of the Excel file to download (defaults to the 2024 edition if blank)
UN_MONITOR_EXCEL_URL=
# Alternatively, point to a pre-downloaded local file to skip the download
UN_MONITOR_LOCAL_PATH=                  # e.g. /data/GEM_2024_Country-Data.xlsx

# ── Basel Convention party data ───────────────────────────────────────────────
# Path to a downloaded Basel party status CSV/Excel (see data-pipeline/ingestion/sources/basel/data/README.md)
BASEL_LOCAL_PATH=                       # e.g. /data/basel_parties.xlsx
